    <div id="ui-container">
        <div class="stats">Khoảng cách: <span id="score">0</span>m</div>
        <div class="stats">Xăng: <span id="fuel">100</span>%</div>
        <div class="stats">Tiền xu: <span id="coins">0</span></div>
    </div>

    <canvas id="game" width="900" height="400"></canvas>

    <div class="controls">
