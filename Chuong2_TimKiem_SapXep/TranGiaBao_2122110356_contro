#include <iostream>
using namespace std;

// Ham nhan con tro va thay doi gia tri
void increase(int* p) {
    *p = *p + 10;  // tang gia tri cua bien tro toi
}

int main() {
    cout << "=== Vi du 1: Con tro tro toi bien ===" << endl;
    int a = 5;
    int* p = &a;  // p tro toi a

    cout << "Dia chi cua a: " << &a << endl;
    cout << "Dia chi luu trong p: " << p << endl;
    cout << "Gia tri a thong qua con tro: " << *p << endl;

    *p = 20;  // thay doi gia tri a thong qua con tro
    cout << "Gia tri a sau khi thay doi qua con tro: " << a << endl;

    cout << "\n=== Vi du 2: Con tro tro toi mang ===" << endl;
    int arr[5] = { 1,2,3,4,5 };
    int* ptrArr = arr;  // ptrArr tro toi arr[0]

    cout << "Mang qua con tro: ";
    for (int i = 0; i < 5; i++) {
        cout << *(ptrArr + i) << " ";  // truy xuat tung phan tu qua con tro
    }
    cout << endl;

    cout << "\n=== Vi du 3: Con tro truyen vao ham ===" << endl;
    int b = 30;
    cout << "Truoc khi goi ham, b = " << b << endl;
    increase(&b);  // truyen dia chi cua b
    cout << "Sau khi goi ham, b = " << b << endl;

    return 0;
}
